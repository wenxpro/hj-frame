<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <!-- 应用名称 -->
    <springProperty scope="context" name="app_name" source="spring.application.name" defaultValue="v3-app"/>
    
    <!-- 环境配置 -->
    <springProfile name="dev,test">
        <property name="log.level.root" value="DEBUG"/>
        <property name="log.level.console" value="DEBUG"/>
    </springProfile>
    <springProfile name="prod">
        <property name="log.level.root" value="INFO"/>
        <property name="log.level.console" value="WARN"/>
    </springProfile>
    
    <!-- 日志存放路径 -->
    <property name="log.path" value="./data/${app_name}/logs"/>
    
    <!-- Spring Boot 标准彩色日志格式 -->
    <include resource="org/springframework/boot/logging/logback/defaults.xml"/>
    
    <!-- 统一日志格式 - 包含线程号 -->
    <property name="LOG_PATTERN" 
              value="%d{yyyy-MM-dd HH:mm:ss.SSS} #%X{trace-id:-} [%thread] %-5level %logger{50} - %msg%n"/>
    
    <!-- 自定义控制台彩色日志格式 - Spring Boot 风格 -->
    <property name="CONSOLE_LOG_PATTERN" 
              value="%clr(%d{${LOG_DATEFORMAT_PATTERN:-yyyy-MM-dd HH:mm:ss.SSS}}){faint} %clr(${LOG_LEVEL_PATTERN:-%5p}) %clr(${PID:- }){magenta} %clr(---){faint} %clr([%15.15t]){faint} %clr(%-40.40logger{39}){cyan} %clr(:){faint} %clr(#%X{trace-id:-}){yellow} %m%n${LOG_EXCEPTION_CONVERSION_WORD:-%wEx}"/>
    
    <!-- 控制台输出 - Spring Boot 风格彩色日志 -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <filter class="ch.qos.logback.classic.filter.ThresholdFilter">
            <level>${log.level.console}</level>
        </filter>
        <encoder class="ch.qos.logback.classic.encoder.PatternLayoutEncoder">
            <pattern>${CONSOLE_LOG_PATTERN}</pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>
    
    <!-- 文件输出 -->
    <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${log.path}/app.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>${log.path}/app.%d{yyyy-MM-dd}.%i.log.gz</fileNamePattern>
            <maxFileSize>100MB</maxFileSize>
            <maxHistory>30</maxHistory>
            <totalSizeCap>5GB</totalSizeCap>
        </rollingPolicy>
        <encoder>
            <pattern>${LOG_PATTERN}</pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>

    <!-- ERROR级别日志 -->
    <appender name="FILE_ERROR" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${log.path}/error.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>${log.path}/error.%d{yyyy-MM-dd}.%i.log.gz</fileNamePattern>
            <maxFileSize>50MB</maxFileSize>
            <maxHistory>60</maxHistory>
            <totalSizeCap>3GB</totalSizeCap>
        </rollingPolicy>
        <encoder>
            <pattern>${LOG_PATTERN}</pattern>
            <charset>UTF-8</charset>
        </encoder>
        <filter class="ch.qos.logback.classic.filter.LevelFilter">
            <level>ERROR</level>
            <onMatch>ACCEPT</onMatch>
            <onMismatch>DENY</onMismatch>
        </filter>
    </appender>
    
    <!-- HTTP请求日志 - 包含线程号 -->
    <appender name="HTTP_LOG" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${log.path}/http.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>${log.path}/http.%d{yyyy-MM-dd}.%i.log.gz</fileNamePattern>
            <maxFileSize>200MB</maxFileSize>
            <maxHistory>7</maxHistory>
            <totalSizeCap>2GB</totalSizeCap>
        </rollingPolicy>
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} #%X{trace-id:-} [%thread] %msg%n</pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>

    <!-- Service性能日志 - 包含线程号 -->
    <appender name="SERVICE_LOG" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${log.path}/service.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>${log.path}/service.%d{yyyy-MM-dd}.%i.log.gz</fileNamePattern>
            <maxFileSize>100MB</maxFileSize>
            <maxHistory>7</maxHistory>
            <totalSizeCap>1GB</totalSizeCap>
        </rollingPolicy>
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} #%X{trace-id:-} [%thread] %msg%n</pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>
    
    <!-- 业务代码日志 -->
    <logger name="com.wenx" level="INFO" additivity="false">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="FILE"/>
        <appender-ref ref="FILE_ERROR"/>
    </logger>

    <!-- OAuth2 授权服务日志 - 开发和测试环境启用DEBUG -->
    <springProfile name="dev,test">
        <logger name="com.wenx.v3authserverstarter.service.RedisOAuth2AuthorizationService" level="DEBUG" additivity="false">
            <appender-ref ref="CONSOLE"/>
            <appender-ref ref="FILE"/>
            <appender-ref ref="FILE_ERROR"/>
        </logger>
        
        <logger name="com.wenx.v3auth.service" level="DEBUG" additivity="false">
            <appender-ref ref="CONSOLE"/>
            <appender-ref ref="FILE"/>
            <appender-ref ref="FILE_ERROR"/>
        </logger>
    </springProfile>
    
    <!-- 生产环境 OAuth2 服务保持 INFO 级别 -->
    <springProfile name="prod">
        <logger name="com.wenx.v3authserverstarter.service.RedisOAuth2AuthorizationService" level="INFO" additivity="false">
            <appender-ref ref="CONSOLE"/>
            <appender-ref ref="FILE"/>
            <appender-ref ref="FILE_ERROR"/>
        </logger>
        
        <logger name="com.wenx.v3auth.service" level="INFO" additivity="false">
            <appender-ref ref="CONSOLE"/>
            <appender-ref ref="FILE"/>
            <appender-ref ref="FILE_ERROR"/>
        </logger>
    </springProfile>

    <!-- Spring框架日志 -->
    <logger name="org.springframework" level="WARN"/>
    <logger name="org.springframework.web" level="WARN"/>
    <logger name="servlet.HandlerMapping.Mappings" level="ERROR"/>

    <!-- 第三方库日志 -->
    <logger name="org.apache" level="ERROR"/>
    <logger name="com.alibaba" level="ERROR"/>
    <logger name="io.netty" level="ERROR"/>
    <logger name="ch.qos.logback" level="ERROR"/>

    <!-- Spring Security OAuth2 调试日志 - 仅在开发和测试环境启用 -->
    <springProfile name="dev,test">
        <logger name="org.springframework.security.oauth2" level="DEBUG"/>
        <logger name="org.springframework.security.oauth2.server.authorization" level="DEBUG"/>
        <logger name="org.springframework.security.oauth2.server.authorization.JdbcOAuth2AuthorizationService" level="DEBUG"/>
        <logger name="org.springframework.security.web" level="DEBUG"/>
    </springProfile>

    <root level="${log.level.root}">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="FILE"/>
        <appender-ref ref="FILE_ERROR"/>
    </root>
    
</configuration>